{
  "name": "atomiciq",
  "version": "0.0.5",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build -p android --profile apk --local --output ./build/atomiciq.apk",
    "build:android:aab": "eas build -p android --profile aab --local --output ./build/atomiciq.aab",
    "install:aab": "./scripts/install-aab.sh",
    "build:ios": "eas build -p ios --local",
    "build:android:release": "eas build -p android",
    "build:ios:release": "eas build -p ios",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@expo/ui": "~56.0.17",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "expo": "~56.0.11",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-contacts": "~56.0.9",
    "expo-haptics": "~56.0.3",
    "expo-intent-launcher": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.17",
    "expo-router": "~56.2.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "lucide-react-native": "^1.17.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-country-flag": "^2.0.2",
    "react-native-country-picker-modal": "^2.0.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "uniwind": "~1.8.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "babel-plugin-inline-import": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tailwindcss": "~4.3.0",
    "typescript": "~6.0.3"
  }
}
